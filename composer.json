{
    "name": "dandoetech/laravel-generic-api",
    "description": "Registry-driven CRUD proxy for Laravel. Validation, policies, filtering, and consistent JSON responses.",
    "type": "library",
    "license": "MIT",
    "authors": [{ "name": "Danilo Doelle", "email": "oss@dandoe.tech" }],
    "homepage": "https://github.com/dandoe-tech/laravel-generic-api",
    "keywords": ["php", "laravel", "crud", "api", "rest", "generic-controller"],
    "require": {
        "php": "^8.2 || ^8.3 || ^8.4",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "illuminate/routing": "^10.0 || ^11.0 || ^12.0",
        "illuminate/validation": "^10.0 || ^11.0 || ^12.0",
        "illuminate/auth": "^10.0 || ^11.0 || ^12.0",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0",
        "illuminate/http": "^10.0 || ^11.0 || ^12.0",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0",
        "dandoetech/resource-registry": "^0.1",
        "dandoetech/laravel-resource-registry": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3",
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.11",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0"
    },
    "autoload": { "psr-4": { "DanDoeTech\\LaravelGenericApi\\": "src/" } },
    "autoload-dev": {
        "psr-4": {
            "DanDoeTech\\LaravelGenericApi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "XDEBUG_MODE=off phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-text --coverage-clover=coverage/clover.xml",
        "cs:fix": "php-cs-fixer fix --allow-risky=yes",
        "cs:check": "php-cs-fixer fix --allow-risky=yes --dry-run",
        "stan": "phpstan analyse --memory-limit=1G",
        "qa": [
            "@cs:check",
            "@stan",
            "@test"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "laravel": {
            "providers": ["DanDoeTech\\LaravelGenericApi\\Providers\\GenericApiServiceProvider"]
        }
    }
}
